{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/components/ui/*": ["./src/types/ui/*", "./src/components/ui/*"],
      "@/api/*": ["./src/types/api/*", "./src/api/*"],
      "@/lib/*": ["./src/types/lib/*", "./src/lib/*"],
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "maxNodeModuleJsDepth": 0,
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "src/components/cronoprogramma/**/*.jsx",
    "src/hooks/useCPM.js",
    "src/utils/cpmEngine.js",
    "src/utils/cronoprogrammaAIAgent.js",
    "src/utils/excelToCsvConverter.js",
    "src/utils/importMultimodalCronoprogramma.js",
    "src/utils/parseCronoprogrammaSemplice.js",
    "src/utils/parseGanttWithVision.js",
    "src/utils/parseGoogleSheetColorBars.js",
    "src/utils/parseSimpleGantt.js",
    "src/utils/parseXLSXCronoprogramma.js",
    "src/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist", "src/vite-plugins", "src/components/ui", "src/api", "src/lib"]
} 
